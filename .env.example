# lc-simulator Configuration
# Copy this file to .env and modify as needed

# LeetCode GraphQL API endpoint
LC_GRAPHQL_URL=https://leetcode.com/graphql

# Network settings (seconds)
LC_REQUEST_TIMEOUT=10
LC_RATE_LIMIT_DELAY=2
LC_MAX_RETRY_BACKOFF=30
LC_MAX_RETRY_ATTEMPTS=5
LC_USER_AGENT=Mozilla/5.0 (compatible; LCProblemFetcher/1.0)

# Directory names (relative to project root)
LC_PROBLEMS_DIR=problems
LC_WORKSPACE_DIR=workspace
LC_DATA_DIR=data
LC_BACKUP_DIR=problems_backup
LC_CACHE_DIR=cache

# Problem settings
LC_MAX_TEST_CASES=20
LC_PROGRESS_FILE=progress.json
LC_PROBLEM_PATTERN=[0-9][0-9][0-9]_*.json

# Content validation
LC_MIN_DESCRIPTION_LENGTH=50

# File encoding
LC_JSON_ENCODING=utf-8-sig
